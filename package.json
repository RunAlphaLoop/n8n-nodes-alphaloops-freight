{
  "name": "n8n-nodes-alphaloops-freight",
  "version": "0.1.18",
  "description": "n8n community node for AlphaLoops FMCSA carrier data API",
  "license": "MIT",
  "homepage": "https://github.com/RunAlphaLoop/n8n-nodes-alphaloops-freight#readme",
  "author": "AlphaLoops, Inc. <mitch@runalphaloops.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/RunAlphaLoop/n8n-nodes-alphaloops-freight.git"
  },
  "main": "dist/nodes/AlphaLoops/AlphaLoops.node.js",
  "keywords": [
    "n8n-community-node-package",
    "alphaloops",
    "fmcsa",
    "freight",
    "carrier",
    "trucking"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AlphaLoopsApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AlphaLoops/AlphaLoops.node.js"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "sync-sdk": "bash scripts/sync-sdk.sh",
    "build": "tsc && cp nodes/AlphaLoops/alphaloops.svg dist/nodes/AlphaLoops/",
    "build:sync": "npm run sync-sdk && npm run build",
    "dev": "npx n8n start --tunnel",
    "lint": "eslint nodes/ credentials/",
    "lint:fix": "eslint nodes/ credentials/ --fix",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "n8n-workflow": "^1.72.0",
    "typescript": "^5.4"
  }
}
